TELEGRAM_BOT_TOKEN=your_telegram_bot_token
KEYWORD_RULES_FILE=keywords.yml
NORMALIZE_MAP_FILE=normalize.yml

# Comma-separated numeric user IDs, e.g. 12345,67890
USER_ID_WHITELIST=

# Comma-separated numeric chat/group IDs, e.g. -1001234567890
CHAT_ID_WHITELIST=

# Optional proxy, e.g. http://127.0.0.1:7890
TELEGRAM_PROXY_URL=
